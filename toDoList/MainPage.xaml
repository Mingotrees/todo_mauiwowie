<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="toDoList.MainPage"
             BackgroundColor="#1A1A1A">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,10,20,10">
        
        <Label Text="TO-DO LIST" 
               FontSize="36" 
               FontAttributes="Bold" 
               TextColor="White"
               Margin="0,20,0,30"
               Grid.Row="0"/>

        <VerticalStackLayout Grid.Row="1" Spacing="12" Margin="0,0,0,20">
            
            <Frame BackgroundColor="#2A2A2A" 
                   CornerRadius="20" 
                   Padding="20,15" 
                   HasShadow="False"
                   BorderColor="Transparent">
                <Entry x:Name="titleEntry"
                       Placeholder="Title"
                       PlaceholderColor="#888"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       FontSize="16" />
            </Frame>

            <Frame BackgroundColor="#2A2A2A" 
                   CornerRadius="20" 
                   Padding="20,15" 
                   HasShadow="False"
                   BorderColor="Transparent">
                <Editor x:Name="detailsEditor"
                        Placeholder="Details"
                        PlaceholderColor="#888"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        HeightRequest="80"
                        FontSize="16"
                        AutoSize="TextChanges" />
            </Frame>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,5,0,0">
                <Button x:Name="addBtn"
                        Text="Add"
                        BackgroundColor="#6B9080"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        HeightRequest="45"
                        Clicked="AddToDoItem"
                        Grid.Column="0" />

                <Button x:Name="editBtn"
                        Text="Update"
                        BackgroundColor="#A4C3B2"
                        TextColor="#1A1A1A"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        HeightRequest="45"
                        IsVisible="False"
                        Clicked="EditToDoItem"
                        Grid.Column="1" />

                <Button x:Name="cancelBtn"
                        Text="Cancel"
                        BackgroundColor="#EAB464"
                        TextColor="#1A1A1A"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="15"
                        HeightRequest="45"
                        IsVisible="False"
                        Clicked="CancelEdit"
                        Grid.Column="2" />
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Label Text="My Tasks" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="White" 
                   Margin="0,0,0,10"
                   Grid.Row="0" />

            <ListView x:Name="todoLV"
                  ItemsSource="{Binding TodoItems}"
                  HasUnevenRows="True"
                  SeparatorVisibility="None"
                  BackgroundColor="Transparent"
                  SelectionMode="None"
                  Grid.Row="1">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame Margin="0,5"
                               Padding="20,15"
                               BackgroundColor="{Binding CardColor}"
                               CornerRadius="25"
                               HasShadow="False"
                               BorderColor="Transparent">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    CommandParameter="{Binding .}"
                                    Tapped="OnCardTapped" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="15">

                                <Label Text="{Binding title}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#1A1A1A"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       LineBreakMode="WordWrap" />

                                <Label Text="{Binding detail}"
                                       FontSize="15"
                                       TextColor="#333333"
                                       LineBreakMode="WordWrap"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,8,0,0" />

                                <Button Text="✕"
                                        BackgroundColor="#FF6B6B"
                                        TextColor="White"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="20"
                                        HeightRequest="40"
                                        WidthRequest="40"
                                        Padding="0"
                                        CommandParameter="{Binding .}"
                                        Clicked="DeleteToDoItem"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Grid.RowSpan="2"
                                        VerticalOptions="Center"
                                        HorizontalOptions="End" />
                            </Grid>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Grid>
    </Grid>
</ContentPage>